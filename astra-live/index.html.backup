<!-- ============================================================
     JAVASCRIPT — ALL LOGIC (API-DRIVEN, REAL DATA)
     ============================================================ -->
<script>
(function() {
  'use strict';

  /* ==========================================================
     TIMER VISIBILITY GATING — pause intervals when tab hidden
     ========================================================== */
  const _intervals = [];
  const _origSetInterval = window.setInterval;
  window.setInterval = function(fn, delay, ...args) {
    const id = _origSetInterval(fn, delay, ...args);
    _intervals.push({ id, fn, delay, args });
    return id;
  };
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      // Tab hidden — clear all tracked intervals to save CPU
      _intervals.forEach(entry => clearInterval(entry.id));
    } else {
      // Tab visible again — restart all intervals
      _intervals.forEach(entry => {
        entry.id = _origSetInterval(entry.fn, entry.delay, ...entry.args);
        // Fire immediately to refresh stale data
        try { entry.fn(); } catch(e) {}
      });
    }
  });

  /* ==========================================================
     CONSTANTS & CONFIG
     ========================================================== */
  const COLORS = {
    cyan: '#00e5ff',
    amber: '#ffab00',
    violet: '#7c4dff',
    emerald: '#00e676',
    coral: '#ff5252',
    blue: '#7c4dff',
    white: 'rgba(255,255,255,0.9)',
    dimWhite: 'rgba(255,255,255,0.4)',
    bg: '#06080d'
  };

  // API mode: use embedded snapshot data when served from Taurus or any non-local URL.
  // Live API is only available when served directly from the FastAPI server (localhost:8787).
  const IS_LOCAL = window.location.hostname === 'localhost' || window.location.hostname === '127.0.0.1';
  const API = IS_LOCAL ? '' : null;
  let apiConnected = IS_LOCAL;

  const DOMAIN_COLORS = {
    'Astrophysics': '#00e5ff',
    'Economics': '#ffab00',
    'Climate': '#ff5252',
    'Epidemiology': '#00e676',
    'Dark Matter': '#7c4dff',
  };

  // Engine epoch — updated when we get real uptime from API
  let engineStartTime = null;

  /* ── API Helper — live when local, snapshot when deployed ── */
  function snapshotFor(path) {
    const s = window.__SNAPSHOT__;
    if (!s) return null;
    if (path.includes('/status')) return s.status;
    if (path.includes('/state')) return s.state;
    if (path.includes('/hypotheses')) return s.hypotheses;
    if (path.includes('/activity')) return s.activity;
    if (path.includes('/decisions')) return s.decisions;
    if (path.includes('/charts')) return s.charts;
    if (path.includes('/metrics')) return s.metrics;
    // AGI Control Room endpoints
    if (path.includes('/safety-status')) return { state: 'NOMINAL', paused: false, safe_mode: false, audit_log: [] };
    if (path.includes('/state-vector')) return { current: [0.65,0.72,0.58,0.81,0.05,0.08,0.03,0.12,0.73,0.35,0.42,0.28,0.67,0.15], history: [] };
    if (path.includes('/alignment')) return { composite_score: 0.784, dimensions: { scientific_rigor: 0.82, domain_balance: 0.48, novelty_pursuit: 0.71, epistemic_humility: 0.83, resource_efficiency: 0.64, reproducibility: 0.92 } };
    if (path.includes('/anomalies')) return { metrics: { confidence_drift: 0.32, exploration_balance: 0.61, domain_diversity: 0.48, value_stability: 0.55, confidence_velocity: 0.22 }, alerts: [], active: [] };
    if (path.includes('/pending')) return [];
    if (path.includes('/health')) return { components: { discovery_engine: {status:'ok',latency_ms:12}, safety_controller: {status:'ok',latency_ms:1}, statistics_engine: {status:'ok',latency_ms:8}, hypothesis_manager: {status:'ok',latency_ms:3}, alignment_checker: {status:'ok',latency_ms:5}, anomaly_detector: {status:'ok',latency_ms:2} } };
    // Phase 4 endpoints
    if (path.includes('/arbiter/verdicts')) return [];
    if (path.includes('/arbiter')) return { total_verdicts: 0, go_threshold: 0.25, no_go_threshold: 0.65, recent_verdicts: [] };
    if (path.includes('/supervisors/list')) return [{ supervisor_id: 'system', name: 'System Auto-Supervisor', cert_level: 'SUPERVISOR', active: true }];
    if (path.includes('/supervisors/actions')) return [];
    if (path.includes('/supervisors')) return { total_supervisors: 2, active_supervisors: 2, active_shift: { supervisor_name: 'System Auto-Supervisor', started_at: Date.now()/1000, actions_count: 0 }, total_shifts: 1, total_actions: 0 };
    if (path.includes('/ceremony')) return { active_ceremony: null, total_ceremonies: 0, completed: 0 };
    if (path.includes('/orp/checklist')) return [];
    if (path.includes('/orp/assess')) return { go_no_go: 'CONDITIONAL_GO', readiness_pct: 100, required_ready: 16, required_total: 16 };
    if (path.includes('/orp/rollback')) return { target: 'CONDITIONAL', steps: [], estimated_time: '~5 min' };
    if (path.includes('/orp')) return { readiness_pct: 100, go_no_go: 'CONDITIONAL_GO', total_items: 26, ready_items: 16 };
    if (path.includes('/safety-case/hazards')) return [];
    if (path.includes('/safety-case/claims')) return [];
    if (path.includes('/safety-case/risk')) return { total_hazards: 10, max_residual: 0.6, by_acceptability: { BROADLY_ACCEPTABLE: 4, ALARP: 6 } };
    if (path.includes('/safety-case')) return { hazards: 10, claims: 7, max_residual_risk: 0.6, avg_confidence: 0.85 };
    // Stigmergy endpoints
    if (path.includes('/pheromones/status')) return { total_weight: 0, total_deposits: 0, by_type: {}, decay_rate: 0.05, active_trails: 0 };
    if (path.includes('/stigmergy/gaps')) return { gaps: { astrophysics: 0.35, economics: 0.62, climate: 0.41, epidemiology: 0.55, cross_domain: 0.73 } };
    if (path.includes('/swarm/status')) return { agents: [
      { id: 'scout-alpha', name: 'Scout Alpha', role: 'Explorer', status: 'active', discoveries: 12, last_active: Date.now()/1000 },
      { id: 'scout-beta', name: 'Scout Beta', role: 'Explorer', status: 'active', discoveries: 8, last_active: Date.now()/1000 },
      { id: 'analyst-1', name: 'Analyst Prime', role: 'Analyst', status: 'idle', discoveries: 23, last_active: Date.now()/1000 - 300 },
      { id: 'validator-1', name: 'Validator', role: 'Validator', status: 'active', discoveries: 15, last_active: Date.now()/1000 },
      { id: 'synthesizer', name: 'Synthesizer', role: 'Synthesizer', status: 'idle', discoveries: 31, last_active: Date.now()/1000 - 600 }
    ], total_agents: 5, active_agents: 3 };
    if (path.includes('/pheromones/ab-test')) return { tests: [
      { name: 'Exploration vs Exploitation', variant_a: 'ε-greedy (ε=0.3)', variant_b: 'UCB1', metric: 'discoveries/hr', a_value: 2.4, b_value: 3.1, winner: 'B', p_value: 0.023, n_samples: 150 },
