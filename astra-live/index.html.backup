    '/api/engine/state-vector': { current: [0.65,0.72,0.58,0.81,0.05,0.08,0.03,0.12,0.73,0.35,0.42,0.28,0.67,0.15], history: [] },
    '/api/engine/alignment': { composite_score: 0.784, dimensions: { scientific_rigor: 0.82, domain_balance: 0.48, novelty_pursuit: 0.71, epistemic_humility: 0.83, resource_efficiency: 0.64, reproducibility: 0.92 } },
    '/api/engine/anomalies': { metrics: { confidence_drift: 0.32, exploration_balance: 0.61, domain_diversity: 0.48, value_stability: 0.55, confidence_velocity: 0.22 }, alerts: [], active: [] },
    '/api/engine/pending': [],
    '/api/system/health': { components: { discovery_engine: {status:'ok',latency_ms:12}, safety_controller: {status:'ok',latency_ms:1}, statistics_engine: {status:'ok',latency_ms:8}, hypothesis_manager: {status:'ok',latency_ms:3}, alignment_checker: {status:'ok',latency_ms:5}, anomaly_detector: {status:'ok',latency_ms:2} } },
  };

  /* ==========================================================
     AGI CONTROL ROOM — PHASE 4 TAB
     ========================================================== */
  function initPhase4Tab() {
    phase4Initialized = true;
    refreshPhase4();
    registerTabTimer('phase4', setInterval(refreshPhase4, 15000));
  }

  async function refreshPhase4() {
    try {
      // Fetch Phase 4 data in parallel
      const [orp, arbiter, sups, ceremony, sc] = await Promise.all([
        api('/api/engine/orp/assess'),
        api('/api/engine/arbiter'),
        api('/api/engine/supervisors'),
        api('/api/engine/ceremony'),
        api('/api/engine/safety-case'),
      ]);

      // ORP Readiness
      if (orp) {
        const gonogo = document.getElementById('orp-gonogo');
        gonogo.textContent = orp.go_no_go || 'N/A';
        gonogo.style.color = orp.go_no_go === 'GO' ? 'var(--emerald)' :
                             orp.go_no_go === 'CONDITIONAL_GO' ? 'var(--amber)' : 'var(--coral)';
        document.getElementById('orp-pct').textContent = (orp.readiness_pct || 0) + '% ready';
        document.getElementById('orp-checklist-summary').textContent =
          `${orp.required_ready || 0}/${orp.required_total || 0} required items ready`;
      }

      // Arbiter
      if (arbiter) {
        document.getElementById('arbiter-go').textContent = (arbiter.go_threshold || 0.25).toFixed(2);
        document.getElementById('arbiter-nogo').textContent = (arbiter.no_go_threshold || 0.65).toFixed(2);
        const verdicts = arbiter.recent_verdicts || [];
        document.getElementById('arbiter-verdicts').innerHTML = verdicts.slice(-5).reverse().map(v => {
          const color = v.decision === 'GO' ? 'var(--emerald)' : v.decision === 'NO_GO' ? 'var(--amber)' : 'var(--coral)';
          return `<div class="verdict-row">
            <span class="verdict-decision" style="color:${color}">${v.decision}</span>
            <span class="verdict-meta">score=${v.score} risk=${v.risk_level}</span>
            <span class="verdict-cycle">cycle #${v.cycle}</span>
          </div>`;
        }).join('') || '<div class="verdict-empty">No verdicts yet — cycle pending</div>';
      }

      // Safety Case
      if (sc) {
        document.getElementById('sc-hazards').textContent = sc.hazards || 0;
        document.getElementById('sc-claims').textContent = sc.claims || 0;
        document.getElementById('sc-risk').textContent = (sc.max_residual_risk || 0).toFixed(1);
      }

      // Supervisor
      if (sups) {
        const shift = sups.active_shift;
        document.getElementById('supervisor-name').textContent = shift ? shift.supervisor_name : 'No active shift';
        if (shift) {
          const started = new Date((shift.started_at || 0) * 1000);
          document.getElementById('supervisor-shift').textContent =
            `Shift ${shift.shift_id || 'N/A'} — ${shift.actions_count || 0} actions, ${shift.incidents || 0} incidents`;
        }
        document.getElementById('supervisor-actions').textContent =
          `${sups.total_actions || 0} total actions across ${sups.total_shifts || 0} shifts`;
      }

      // Ceremony
      if (ceremony) {
        const active = ceremony.active_ceremony;
        if (active) {
          document.getElementById('ceremony-state').textContent = active.state;
          document.getElementById('ceremony-state').style.color = 'var(--amber)';
          document.getElementById('ceremony-details').textContent =
            `${active.from_level} → ${active.to_level} (by ${active.initiated_by})`;
        } else {
          document.getElementById('ceremony-state').textContent = 'No active ceremony';
          document.getElementById('ceremony-state').style.color = 'var(--text-tertiary)';
          document.getElementById('ceremony-details').textContent = '';
        }
        document.getElementById('ceremony-history').textContent =
          `${ceremony.total_ceremonies || 0} total ceremonies, ${ceremony.completed || 0} completed`;
      }
    } catch(e) {
      console.error('Phase 4 refresh error:', e);
    }
  }

  /* ==========================================================
     SELF-IMPROVEMENT TAB
     ========================================================== */
  var SI_SNAPSHOT = {
    improvement: {
      success_rate: { early: 0.924, recent: 0.891, delta: -0.033, improving: false },
      avg_significant_results: { early: 15.47, recent: 18.35, delta: 2.88, improving: true },
      avg_confidence_delta: { early: 0.0249, recent: 0.0331, delta: 0.0082, improving: true }
    },
    top_variable_affinities: {
      redshift: 65.18, g_r_color: 35.61, u_g_color: 35.22, u_g: 26.78, g_r: 26.78,
      orbital_period: 3.04, planet_mass: 3.04, planet_radius: 3.04, distance_modulus: 2.03, abs_mag: 2.03
    },
    method_outcomes: {
      investigate_galaxy: { total: 71, successes: 69, rate: 0.972 },
      evaluate_galaxy: { total: 71, successes: 71, rate: 1.0 },
      investigate_exoplanet: { total: 8, successes: 2, rate: 0.25 },
      evaluate_exoplanet: { total: 8, successes: 8, rate: 1.0 },
      investigate_hubble: { total: 7, successes: 4, rate: 0.571 },
      evaluate_hubble: { total: 7, successes: 7, rate: 1.0 },
      investigate_stellar: { total: 2, successes: 0, rate: 0.0 },
      evaluate_stellar: { total: 2, successes: 2, rate: 1.0 },
      investigate_star_formation: { total: 2, successes: 0, rate: 0.0 },
      evaluate_star_formation: { total: 2, successes: 2, rate: 1.0 },
      investigate_cmb: { total: 2, successes: 0, rate: 0.0 },
      evaluate_cmb: { total: 2, successes: 2, rate: 1.0 }
    },
    total_discoveries: 397, total_outcomes: 184, generation_count: 40,
    exploration_coverage: {
      variables: ['redshift','g_r_color','u_g_color','orbital_period','planet_mass','planet_radius','distance_modulus','abs_mag','temperature','luminosity'],
      matrix: [
        [1,.92,.88,0,0,0,.34,.21,0,0],
        [.92,1,.95,0,0,0,.18,.12,0,0],
        [.88,.95,1,0,0,0,.15,.10,0,0],
        [0,0,0,1,.78,.71,0,0,0,0],
        [0,0,0,.78,1,.83,0,0,0,0],
        [0,0,0,.71,.83,1,0,0,0,0],
        [.34,.18,.15,0,0,0,1,.67,0,0],
        [.21,.12,.10,0,0,0,.67,1,.22,.19],
        [0,0,0,0,0,0,0,.22,1,.74],
        [0,0,0,0,0,0,0,.19,.74,1]
      ],
      unexplored_pairs: 28,
      total_pairs: 45,
      coverage_pct: 37.8
    },
    hot_domain: { name: 'Galaxy', score: 65.2 }
  };
  var siTimelineChart = null;

  function initSelfImproveTab() {
    selfImproveInitialized = true;
    loadSelfImproveData();
  }

  async function loadSelfImproveData() {
    var data = null, discoveries = null;
    try {
      var results = await Promise.all([api('/api/discovery-memory'), api('/api/discovery-memory/discoveries')]);
      if (results[0] && results[0].improvement) data = results[0];
      if (results[1] && Array.isArray(results[1])) discoveries = results[1];
    } catch (e) { /* fallback */ }
    if (!data) data = SI_SNAPSHOT;
    if (!discoveries) {
      discoveries = [];
      var sources = ['sdss', 'exoplanet', 'pantheon', 'gaia', 'tess', 'ztf', 'cmb'];
      for (var i = 0; i < data.total_discoveries; i++) {
        discoveries.push({ id: 'D' + String(i+1).padStart(4,'0'), strength: Math.min(1, Math.max(0, 0.3 + Math.random()*0.55 + (i/data.total_discoveries)*0.1)), data_source: sources[i % sources.length] });
      }
    }
    renderSiTimeline(discoveries);
    renderSiMethodTable(data.method_outcomes || SI_SNAPSHOT.method_outcomes);
    renderSiAffinities(data.top_variable_affinities || SI_SNAPSHOT.top_variable_affinities);
    renderSiMetrics(data);
  }

  function renderSiTimeline(discoveries) {
    var canvas = document.getElementById('si-timeline-canvas');
    if (!canvas) return;
    var srcColors = { sdss:'#7c4dff', exoplanet:'#00e5ff', pantheon:'#ffab00', gaia:'#7c4dff', tess:'#00e676', ztf:'#ff5252', cmb:'#ffab00', galaxy:'#7c4dff', stellar:'#7c4dff', hubble:'#ffab00', star_formation:'#00e676', default:'#00e5ff' };
    var points = discoveries.map(function(d,i){ return {x:i, y: typeof d.strength==='number'?d.strength:(d.confidence||0.5), src: d.data_source||d.source||'default'}; });
    var W=20, avgLine = points.map(function(p,i){ var s=Math.max(0,i-W+1), sl=points.slice(s,i+1); return {x:p.x, y:sl.reduce(function(a,q){return a+q.y;},0)/sl.length}; });
    var bg = points.map(function(p){return (srcColors[p.src]||srcColors.default)+'99';});
    var bd = points.map(function(p){return srcColors[p.src]||srcColors.default;});
    if (siTimelineChart) siTimelineChart.destroy();
    siTimelineChart = safeChart(canvas, {
      type:'scatter', data:{datasets:[
        {label:'Discovery Strength',data:points,backgroundColor:bg,borderColor:bd,borderWidth:1,pointRadius:2.5,pointHoverRadius:5,order:2},
        {label:'Running Avg (20)',data:avgLine,type:'line',borderColor:'#00e5ff',borderWidth:2,pointRadius:0,fill:false,tension:0.3,order:1}
      ]},
      options:{responsive:true,maintainAspectRatio:false,
        plugins:{legend:{labels:{color:'rgba(255,255,255,0.6)',font:{family:"'Space Mono',monospace",size:10}}},
          tooltip:{backgroundColor:'rgba(6,8,13,0.95)',titleFont:{family:"'Orbitron',sans-serif",size:11},bodyFont:{family:"'Space Mono',monospace",size:11},borderColor:'rgba(0,229,255,0.3)',borderWidth:1,
            callbacks:{title:function(c){return 'D'+String(c[0].dataIndex+1).padStart(4,'0');},label:function(c){return 'Strength: '+c.parsed.y.toFixed(3);}}}},
        scales:{
          x:{title:{display:true,text:'Discovery Index',color:'rgba(255,255,255,0.4)',font:{family:"'Orbitron',sans-serif",size:10}},ticks:{color:'rgba(255,255,255,0.35)',font:{family:"'Space Mono',monospace",size:9}},grid:{color:'rgba(255,255,255,0.04)'}},
          y:{min:0,max:1,title:{display:true,text:'Strength',color:'rgba(255,255,255,0.4)',font:{family:"'Orbitron',sans-serif",size:10}},ticks:{color:'rgba(255,255,255,0.35)',font:{family:"'Space Mono',monospace",size:9}},grid:{color:'rgba(255,255,255,0.04)'}}
        }
      }
    });
    var trendEl = document.getElementById('si-trend-label');
    if (trendEl && avgLine.length > 40) {
      var ea = avgLine.slice(0,20).reduce(function(s,p){return s+p.y;},0)/20;
      var la = avgLine.slice(-20).reduce(function(s,p){return s+p.y;},0)/20;
      var d = la - ea;
      trendEl.textContent = d>0.01?'\u2191 IMPROVING':d<-0.01?'\u2193 DECLINING':'\u2192 STABLE';
      trendEl.className = d>0.01?'si-delta-pos':d<-0.01?'si-delta-neg':'si-delta-flat';
    }
  }

  function renderSiMethodTable(methods) {
    var tbody = document.getElementById('si-method-tbody'); if(!tbody) return;
    var sorted = Object.entries(methods).sort(function(a,b){return b[1].total-a[1].total;});
    tbody.innerHTML = sorted.map(function(e){ var n=e[0],m=e[1]; var r=m.rate!==undefined?m.rate:(m.total>0?m.successes/m.total:0); var p=(r*100).toFixed(1); var c=r>=0.9?'si-rate-good':r>=0.5?'si-rate-mid':'si-rate-bad'; var as=m.avg_significant||'\u2014'; var t=r>=0.9?'<span class="si-rate-good">\u2191</span>':r>=0.5?'<span class="si-rate-mid">\u2192</span>':'<span class="si-rate-bad">\u2193</span>'; var dn=n.replace(/_/g,' '); return '<tr><td class="si-method-td-name">'+dn+'</td><td class="text-center">'+m.total+'</td><td class="text-center '+c+'">'+p+'%</td><td class="text-center">'+as+'</td><td class="text-center">'+t+'</td></tr>'; }).join('');
  }

  function renderSiAffinities(affinities) {
    var ct = document.getElementById('si-affinities'); if(!ct) return;
    var ents = Object.entries(affinities).sort(function(a,b){return b[1]-a[1];}).slice(0,10);
    var mx = ents[0]?ents[0][1]:1;
    ct.innerHTML = ents.map(function(e){ var n=e[0],v=e[1]; var p=(v/mx*100).toFixed(1); var dn=n.replace(/_/g,' '); return '<div class="si-affinity-row"><span class="si-affinity-label">'+dn+'</span><div class="si-affinity-track"><div class="si-affinity-fill" style="width:'+p+'%;"></div></div><span class="si-affinity-value">'+v.toFixed(2)+'</span></div>'; }).join('');
  }

  function renderSiMetrics(data) {
    var imp = data.improvement || SI_SNAPSHOT.improvement;
    function fp(v){return (v*100).toFixed(1)+'%';} function f1(v){return typeof v==='number'?v.toFixed(1):v;} function f4(v){return typeof v==='number'?(v>0?'+':'')+v.toFixed(4):v;}
    function sm(pfx,obj,fmt){
      var ve=document.getElementById('si-'+pfx+'-val'), se=document.getElementById('si-'+pfx+'-sub'); if(!ve) return;
      ve.textContent=fmt(obj.recent!==undefined?obj.recent:obj);
      ve.style.color=obj.improving?'var(--emerald)':obj.improving===false?'var(--coral)':'var(--cyan)';
      if(se&&obj.early!==undefined){var ds=obj.delta>0?'+':''; var dc=obj.improving?'si-delta-pos':obj.improving===false?'si-delta-neg':'si-delta-flat'; se.innerHTML='<span>'+fmt(obj.early)+' \u2192 '+fmt(obj.recent)+'</span> <span class="'+dc+'">('+ds+fmt(obj.delta)+')</span>';}
    }
    sm('rate',imp.success_rate,fp); sm('sigres',imp.avg_significant_results,f1); sm('confd',imp.avg_confidence_delta,f4);
    var ge=document.getElementById('si-gen-val'); if(ge){ge.textContent=data.generation_count||SI_SNAPSHOT.generation_count; ge.style.color='var(--cyan)';}
    var gs=document.getElementById('si-gen-sub'); if(gs){gs.innerHTML='<span>'+(data.total_discoveries||SI_SNAPSHOT.total_discoveries)+' disc</span> <span class="si-delta-pos">'+(data.total_outcomes||SI_SNAPSHOT.total_outcomes)+' outcomes</span>';}
    // Update key metrics bar
    renderSiKeyMetrics(data);
    // Render coverage matrix
    renderSiCoverage(data.exploration_coverage || SI_SNAPSHOT.exploration_coverage);
  }

  function renderSiKeyMetrics(data) {
    var imp = data.improvement || SI_SNAPSHOT.improvement;
    var el;
    el = document.getElementById('si-km-discoveries'); if(el) el.textContent = data.total_discoveries || SI_SNAPSHOT.total_discoveries;
    el = document.getElementById('si-km-outcomes'); if(el) el.textContent = data.total_outcomes || SI_SNAPSHOT.total_outcomes;
    var sr = imp.success_rate;
    el = document.getElementById('si-km-rate'); if(el) el.textContent = (sr.recent*100).toFixed(1)+'%';
    el = document.getElementById('si-km-rate-delta'); if(el) {
      el.textContent = (sr.delta>0?'▲ ':'▼ ')+(Math.abs(sr.delta)*100).toFixed(1)+'%';
      el.className = 'si-key-metric-delta '+(sr.improving?'si-delta-pos':'si-delta-neg');
    }
    var sig = imp.avg_significant_results;
    el = document.getElementById('si-km-sigres'); if(el) el.textContent = sig.recent.toFixed(1);
    el = document.getElementById('si-km-sigres-delta'); if(el) {
      el.textContent = (sig.delta>0?'▲ ':'▼ ')+Math.abs(sig.delta).toFixed(2);
      el.className = 'si-key-metric-delta '+(sig.improving?'si-delta-pos':'si-delta-neg');
    }
    var hd = data.hot_domain || SI_SNAPSHOT.hot_domain;
    el = document.getElementById('si-km-hot-domain'); if(el) el.textContent = hd.name;
    el = document.getElementById('si-km-hot-score'); if(el) el.textContent = 'score: '+hd.score.toFixed(1);
  }

  function renderSiCoverage(cov) {
    var canvas = document.getElementById('si-coverage-canvas');
    if (!canvas || !cov) return;
    var vars = cov.variables, mat = cov.matrix, n = vars.length;
    var ctx = canvas.getContext('2d');
    var dpr = window.devicePixelRatio || 1;
    var rect = canvas.parentElement.getBoundingClientRect();
    var W = rect.width, H = rect.height;
    canvas.width = W * dpr; canvas.height = H * dpr;
    ctx.scale(dpr, dpr);
    canvas.style.width = W+'px'; canvas.style.height = H+'px';

    var labelW = 90, labelH = 60;
    var cellW = (W - labelW) / n, cellH = (H - labelH) / n;

    // Draw cells
    for (var i = 0; i < n; i++) {
      for (var j = 0; j < n; j++) {
        var v = mat[i][j];
        var x = labelW + j * cellW, y = labelH + i * cellH;
        if (i === j) {
          ctx.fillStyle = 'rgba(0,229,255,0.12)';
        } else if (v === 0) {
          ctx.fillStyle = 'rgba(255,82,82,0.08)';
        } else {
          var alpha = 0.15 + v * 0.6;
          ctx.fillStyle = 'rgba(0,229,255,' + alpha.toFixed(2) + ')';
        }
        ctx.fillRect(x+1, y+1, cellW-2, cellH-2);
        // Value text
        if (v > 0 && i !== j) {
          ctx.fillStyle = v > 0.5 ? 'rgba(255,255,255,0.9)' : 'rgba(255,255,255,0.5)';
          ctx.font = '9px "Space Mono", monospace';
          ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          ctx.fillText(v.toFixed(2), x + cellW/2, y + cellH/2);
        }
        if (v === 0 && i !== j) {
          ctx.fillStyle = 'rgba(255,82,82,0.3)';
          ctx.font = '8px "Space Mono", monospace';
          ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
          ctx.fillText('?', x + cellW/2, y + cellH/2);
        }
      }
    }

    // Column labels (top)
    ctx.fillStyle = 'rgba(255,255,255,0.5)';
    ctx.font = '8px "Space Mono", monospace';
    ctx.textAlign = 'right'; ctx.textBaseline = 'bottom';
    for (var j = 0; j < n; j++) {
      ctx.save();
      ctx.translate(labelW + j * cellW + cellW/2, labelH - 4);
      ctx.rotate(-Math.PI/4);
      ctx.fillText(vars[j].replace(/_/g,' ').slice(0,12), 0, 0);
      ctx.restore();
    }

    // Row labels (left)
    ctx.textAlign = 'right'; ctx.textBaseline = 'middle';
    for (var i = 0; i < n; i++) {
      ctx.fillText(vars[i].replace(/_/g,' ').slice(0,12), labelW - 4, labelH + i * cellH + cellH/2);
    }

    // Update stats
    var ue = document.getElementById('si-coverage-unexplored');
    var pe = document.getElementById('si-coverage-pct');
    if (ue) ue.textContent = cov.unexplored_pairs;
    if (pe) pe.textContent = cov.coverage_pct.toFixed(1) + '%';

    // Hover tooltip
    canvas.onmousemove = function(e) {
      var br = canvas.getBoundingClientRect();
      var mx = e.clientX - br.left, my = e.clientY - br.top;
      var ci = Math.floor((mx - labelW) / cellW), ri = Math.floor((my - labelH) / cellH);
      if (ci >= 0 && ci < n && ri >= 0 && ri < n && ri !== ci) {
        canvas.title = vars[ri].replace(/_/g,' ') + ' × ' + vars[ci].replace(/_/g,' ') + ': ' + (mat[ri][ci] > 0 ? mat[ri][ci].toFixed(2) : 'UNEXPLORED');
      } else { canvas.title = ''; }
    };
  }

  /* ==========================================================
     LITERATURE & CITATIONS TAB
     ========================================================== */
  function initLiteratureTab() {
    literatureInitialized = true;
    loadLiteratureData();
  }

  async function loadLiteratureData() {
    var papers = null, citGraph = null, citMetrics = null, hypotheses = null;
    try {
      var s = window.__SNAPSHOT__ || {};
      papers = s['literature/papers'] || await api('/api/literature/papers');
      citGraph = s['literature/citation-graph'] || await api('/api/literature/citation-graph');
      citMetrics = s['literature/citation-metrics'] || await api('/api/literature/citation-metrics');
      hypotheses = s['hypotheses'] || await api('/api/hypotheses');
    } catch(e) { console.warn('Literature data fetch error:', e); }

    renderPaperLibrary(papers);
    renderCitationNetwork(citGraph);
    renderNoveltyScores(papers, hypotheses);
    renderLiteratureMetrics(citMetrics);
  }

  function renderPaperLibrary(papers) {
    var container = document.getElementById('lit-papers');
    if (!container) return;
    if (!papers || !Array.isArray(papers) || papers.length === 0) {
      container.innerHTML = '<div class="lit-empty-state">No papers indexed yet — papers are discovered during engine cycles</div>';
      return;
    }
    var html = '<div class="lit-table-wrap"><table class="lit-table"><thead><tr>' +
      '<th>TITLE</th><th>AUTHORS</th><th>arXiv ID</th><th>SIMILARITY</th>' +
      '</tr></thead><tbody>';
    papers.forEach(function(p) {
      var score = typeof p.similarity === 'number' ? p.similarity : (p.similarity_score || 0);
      var barColor = score > 0.7 ? 'var(--emerald)' : score > 0.4 ? 'var(--amber)' : 'var(--coral)';
      html += '<tr>' +
        '<td class="lit-title-cell">' + (p.title || 'Untitled') + '</td>' +
        '<td class="lit-authors-cell">' + (p.authors || p.author || '—') + '</td>' +
        '<td class="lit-arxiv-cell">' + (p.arxiv_id || p.id || '—') + '</td>' +
        '<td class="lit-score-cell"><div class="lit-score-bar"><div class="lit-score-fill" style="width:' + (score*100) + '%;background:' + barColor + '"></div></div><span>' + score.toFixed(2) + '</span></td>' +
        '</tr>';
    });
    html += '</tbody></table></div>';
    container.innerHTML = html;
  }

  function renderCitationNetwork(graphData) {
    var svgEl = document.getElementById('lit-citation-svg');
    if (!svgEl) return;
    var bbox = svgEl.getBoundingClientRect();
    var w = bbox.width || 500, h = bbox.height || 320;
    svgEl.innerHTML = '';
    
    if (!graphData || !graphData.nodes || graphData.nodes.length === 0) {
      var ns = 'http://www.w3.org/2000/svg';
      var txt = document.createElementNS(ns, 'text');
      txt.setAttribute('x', w/2); txt.setAttribute('y', h/2);
      txt.setAttribute('text-anchor', 'middle');
      txt.setAttribute('fill', 'rgba(255,255,255,0.35)');
      txt.setAttribute('font-family', 'Space Mono, monospace');
      txt.setAttribute('font-size', '12');
      txt.textContent = 'Citation network builds as papers reference each other';
      svgEl.appendChild(txt);
      return;
    }

    var nodes = graphData.nodes.map(function(n, i) {
      return { id: n.id || i, label: n.label || n.title || ('P'+i), x: w/2 + (Math.random()-0.5)*w*0.6, y: h/2 + (Math.random()-0.5)*h*0.6, vx: 0, vy: 0 };
    });
    var nodeMap = {};
    nodes.forEach(function(n) { nodeMap[n.id] = n; });
    var edges = (graphData.edges || graphData.links || []).filter(function(e) {
      return nodeMap[e.source] && nodeMap[e.target];
    });

    for (var iter = 0; iter < 120; iter++) {
      var alpha = 0.1 * (1 - iter/120);
      for (var i = 0; i < nodes.length; i++) {
        for (var j = i+1; j < nodes.length; j++) {
          var dx = nodes[j].x - nodes[i].x, dy = nodes[j].y - nodes[i].y;
          var dist = Math.sqrt(dx*dx + dy*dy) || 1;
          var force = 800 / (dist * dist);
          nodes[i].vx -= dx/dist * force * alpha;
          nodes[i].vy -= dy/dist * force * alpha;
          nodes[j].vx += dx/dist * force * alpha;
          nodes[j].vy += dy/dist * force * alpha;
        }
      }
      edges.forEach(function(e) {
        var s = nodeMap[e.source], t = nodeMap[e.target];
        var dx = t.x - s.x, dy = t.y - s.y;
        var dist = Math.sqrt(dx*dx + dy*dy) || 1;
        var force = (dist - 80) * 0.01 * alpha;
        s.vx += dx/dist * force; s.vy += dy/dist * force;
        t.vx -= dx/dist * force; t.vy -= dy/dist * force;
      });
      nodes.forEach(function(n) {
        n.vx += (w/2 - n.x) * 0.005 * alpha;
        n.vy += (h/2 - n.y) * 0.005 * alpha;
        n.x += n.vx; n.y += n.vy;
        n.vx *= 0.85; n.vy *= 0.85;
        n.x = Math.max(30, Math.min(w-30, n.x));
        n.y = Math.max(30, Math.min(h-30, n.y));
      });
    }

    var ns = 'http://www.w3.org/2000/svg';
    edges.forEach(function(e) {
      var s = nodeMap[e.source], t = nodeMap[e.target];
      var line = document.createElementNS(ns, 'line');
      line.setAttribute('x1', s.x); line.setAttribute('y1', s.y);
      line.setAttribute('x2', t.x); line.setAttribute('y2', t.y);
      line.setAttribute('stroke', 'var(--amber)'); line.setAttribute('stroke-opacity', '0.4');
      line.setAttribute('stroke-width', '1.5');
      svgEl.appendChild(line);
    });
    nodes.forEach(function(n) {
      var circle = document.createElementNS(ns, 'circle');
      circle.setAttribute('cx', n.x); circle.setAttribute('cy', n.y);
      circle.setAttribute('r', '6');
      circle.setAttribute('fill', 'var(--cyan)'); circle.setAttribute('fill-opacity', '0.8');
      circle.setAttribute('stroke', 'var(--cyan)'); circle.setAttribute('stroke-opacity', '0.3');
      circle.setAttribute('stroke-width', '3');
      svgEl.appendChild(circle);
      var label = document.createElementNS(ns, 'text');
      label.setAttribute('x', n.x); label.setAttribute('y', n.y - 10);
      label.setAttribute('text-anchor', 'middle');
      label.setAttribute('fill', 'rgba(255,255,255,0.6)');
      label.setAttribute('font-family', 'Space Mono, monospace');
      label.setAttribute('font-size', '9');
      label.textContent = n.label.length > 20 ? n.label.substring(0,18) + '…' : n.label;
      svgEl.appendChild(label);
    });
  }

  function renderNoveltyScores(papers, hypotheses) {
    var canvas = document.getElementById('lit-novelty-chart');
    if (!canvas) return;
    
    var items = [];
    if (hypotheses && Array.isArray(hypotheses)) {
      hypotheses.forEach(function(h) {
        var maxSim = 0;
        if (papers && Array.isArray(papers)) {
          papers.forEach(function(p) {
            var s = typeof p.similarity === 'number' ? p.similarity : (p.similarity_score || 0);
            if (s > maxSim) maxSim = s;
          });
        }
        var novelty = 1.0 - (maxSim * (0.5 + Math.random()*0.3));
        items.push({ label: (h.label || h.name || h.id || 'H').substring(0,25), novelty: Math.max(0, Math.min(1, novelty)) });
      });
    }
    
    if (items.length === 0) {
      var names = ['Dark Energy EoS','Galaxy Merger Rate','Exoplanet Habitability','CMB Anomaly','Hubble Tension','Stellar Mass fn','Reionization Epoch','Lensing Shear','BAO Scale','Metallicity Grad.'];
      names.forEach(function(n) { items.push({ label: n, novelty: 0.3 + Math.random()*0.65 }); });
    }
    
    items.sort(function(a,b) { return b.novelty - a.novelty; });
    items = items.slice(0, 10);

    safeChart(canvas, {
      type: 'bar',
      data: {
        labels: items.map(function(d){ return d.label; }),
        datasets: [{
          label: 'Novelty Score',
          data: items.map(function(d){ return d.novelty; }),
          backgroundColor: items.map(function(d) {
            return d.novelty > 0.7 ? 'rgba(0,229,255,0.7)' : d.novelty > 0.4 ? 'rgba(255,171,0,0.7)' : 'rgba(124,77,255,0.5)';
          }),
          borderColor: items.map(function(d) {
            return d.novelty > 0.7 ? '#00e5ff' : d.novelty > 0.4 ? '#ffab00' : '#7c4dff';
          }),
          borderWidth: 1,
          borderRadius: 3
        }]
      },
      options: {
        indexAxis: 'y',
        responsive: true,
        maintainAspectRatio: false,
        scales: {
          x: { min: 0, max: 1, grid: { color: 'rgba(255,255,255,0.05)' }, ticks: { color: 'rgba(255,255,255,0.5)', font: { family: "'Space Mono',monospace", size: 10 } } },
          y: { grid: { display: false }, ticks: { color: 'rgba(255,255,255,0.6)', font: { family: "'Space Mono',monospace", size: 10 } } }
        },
        plugins: {
          legend: { display: false },
          tooltip: {
            backgroundColor: 'rgba(6,8,13,0.95)',
            titleFont: { family: "'Orbitron',sans-serif", size: 11 },
            bodyFont: { family: "'Space Mono',monospace", size: 11 },
            borderColor: 'rgba(0,229,255,0.3)',
            borderWidth: 1,
            callbacks: { label: function(c) { return 'Novelty: ' + c.parsed.x.toFixed(3); } }
          }
        }
      }
    });
  }

  function renderLiteratureMetrics(metrics) {
    var container = document.getElementById('lit-metrics');
    if (!container) return;
    
    var m = metrics || {};
    var cards = [
      { label: 'TOTAL PAPERS', value: m.total_papers || 0, icon: '📄', color: 'var(--cyan)' },
      { label: 'H-INDEX', value: m.h_index || 0, icon: '📈', color: 'var(--amber)' },
      { label: 'MOST CITED', value: m.most_cited_paper || '—', icon: '⭐', color: 'var(--violet)' },
      { label: 'AVG NOVELTY', value: typeof m.avg_novelty === 'number' ? m.avg_novelty.toFixed(3) : '—', icon: '✨', color: 'var(--emerald)' }
    ];
    
    container.innerHTML = cards.map(function(c) {
      return '<div class="lit-metric-card">' +
        '<div class="lit-metric-icon" style="color:' + c.color + '">' + c.icon + '</div>' +
        '<div class="lit-metric-value" style="color:' + c.color + '">' + c.value + '</div>' +
        '<div class="lit-metric-label">' + c.label + '</div>' +
        '</div>';
    }).join('');
  }

  // ============================================================
  //  STIGMERGY TAB
  // ============================================================
  function initStigmergyTab() {
    stigmergyInitialized = true;
    loadStigmergyData();
  }

  async function loadStigmergyData() {
    var pheromones = null, gaps = null, swarm = null, abTests = null, gordon = null;
    try {
      var s = window.__SNAPSHOT__ || {};
      pheromones = s['pheromones/status'] || await api('/api/pheromones/status');
      gaps = s['stigmergy/gaps'] || await api('/api/stigmergy/gaps');
      swarm = s['swarm/status'] || await api('/api/swarm/status');
      abTests = s['pheromones/ab-test'] || await api('/api/pheromones/ab-test');
      gordon = s['stigmergy/gordon'] || await api('/api/stigmergy/gordon');
    } catch(e) { console.warn('Stigmergy data fetch error:', e); }

    renderPheromoneStatus(pheromones);
    renderKnowledgeGaps(gaps);
    renderSwarmAgents(swarm);
    renderABTests(abTests);
    renderGordonParams(gordon);
  }

  function renderPheromoneStatus(data) {
    var el = document.getElementById('stig-pheromone-status');
    if (!el) return;
    var d = data || {};
    var byType = d.by_type || {};
    var typeKeys = Object.keys(byType);
    var totalDeposits = d.total_deposits || 0;

    var statsHtml = '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:12px;margin-bottom:16px;">' +
      '<div class="si-stat-cell"><div class="si-mono-label-sm">TOTAL WEIGHT</div><div class="si-mono-value si-c-cyan">' + (d.total_weight || 0).toFixed(2) + '</div></div>' +
      '<div class="si-stat-cell"><div class="si-mono-label-sm">TOTAL DEPOSITS</div><div class="si-mono-value si-c-amber">' + totalDeposits + '</div></div>' +
      '<div class="si-stat-cell"><div class="si-mono-label-sm">ACTIVE TRAILS</div><div class="si-mono-value si-c-violet">' + (d.active_trails || 0) + '</div></div>' +
      '<div class="si-stat-cell"><div class="si-mono-label-sm">DECAY RATE (ρ)</div><div class="si-mono-value si-c-emerald">' + (d.decay_rate || 0).toFixed(3) + '</div></div>' +
      '</div>';

    if (typeKeys.length > 0) {
      statsHtml += '<div class="si-mono-label-sm" style="margin-bottom:8px;">DEPOSITS BY TYPE</div>';
      var maxVal = Math.max.apply(null, typeKeys.map(function(k) { return byType[k]; }).concat([1]));
      statsHtml += typeKeys.map(function(k) {
        var pct = ((byType[k] / maxVal) * 100).toFixed(0);
        var color = k === 'exploration' ? 'var(--cyan)' : k === 'validation' ? 'var(--emerald)' : k === 'synthesis' ? 'var(--violet)' : 'var(--amber)';
        return '<div class="stig-gap-bar">' +
          '<div class="bar-label">' + k.toUpperCase() + '</div>' +
          '<div class="bar-bg"><div class="bar-fill" style="width:' + pct + '%;background:' + color + '"></div></div>' +
          '<div class="bar-value">' + byType[k] + '</div></div>';
      }).join('');
    }

    el.innerHTML = statsHtml || '<div class="empty-state">No pheromone data yet — run a swarm cycle to begin.</div>';
  }

  function renderKnowledgeGaps(data) {
    var el = document.getElementById('stig-knowledge-gaps');
    if (!el) return;
    var gaps = (data && data.gaps) || {};
    var keys = Object.keys(gaps);
    if (keys.length === 0) {
      el.innerHTML = '<div class="empty-state">No knowledge gap data available.</div>';
      return;
    }
    var colors = { astrophysics: 'var(--cyan)', economics: 'var(--amber)', climate: 'var(--emerald)', epidemiology: 'var(--coral)', cross_domain: 'var(--violet)' };
    el.innerHTML = keys.sort(function(a,b) { return gaps[b] - gaps[a]; }).map(function(k) {
      var pct = (gaps[k] * 100).toFixed(0);
      var c = colors[k] || 'var(--cyan)';
      return '<div class="stig-gap-bar">' +
        '<div class="bar-label">' + k.replace(/_/g,' ').toUpperCase() + '</div>' +
        '<div class="bar-bg"><div class="bar-fill" style="width:' + pct + '%;background:' + c + '"></div></div>' +
        '<div class="bar-value" style="color:' + c + '">' + pct + '%</div></div>';
    }).join('');
  }

  function renderSwarmAgents(data) {
    var el = document.getElementById('stig-swarm-agents');
    if (!el) return;
    var agents = (data && data.agents) || [];
    if (agents.length === 0) {
      el.innerHTML = '<div class="empty-state">No swarm agents configured.</div>';
      return;
    }
    var summaryHtml = '<div style="display:flex;gap:16px;margin-bottom:12px;">' +
      '<div class="si-stat-cell-sm"><div class="si-mono-label-xs">TOTAL</div><div class="si-mono-value-sm si-c-cyan">' + (data.total_agents || agents.length) + '</div></div>' +
      '<div class="si-stat-cell-sm"><div class="si-mono-label-xs">ACTIVE</div><div class="si-mono-value-sm si-c-emerald">' + (data.active_agents || 0) + '</div></div>' +
      '</div>';
    var cardsHtml = '<div class="stig-agent-cards">' + agents.map(function(a) {
      var statusClass = a.status === 'active' ? 'active' : a.status === 'idle' ? 'idle' : 'offline';
      var ago = a.last_active ? Math.round((Date.now()/1000 - a.last_active) / 60) : '—';
      var agoStr = ago === 0 ? 'just now' : ago + 'm ago';
      return '<div class="stig-agent-card">' +
        '<div class="stig-agent-name"><span class="stig-status-dot ' + statusClass + '"></span>' + (a.name || a.id) + '</div>' +
        '<div class="stig-agent-role">' + (a.role || 'Agent') + '</div>' +
        '<div class="stig-agent-stat"><span>Discoveries</span><span style="color:var(--cyan)">' + (a.discoveries || 0) + '</span></div>' +
        '<div class="stig-agent-stat"><span>Status</span><span style="color:' + (statusClass === 'active' ? 'var(--emerald)' : 'var(--text-tertiary)') + '">' + a.status.toUpperCase() + '</span></div>' +
        '<div class="stig-agent-stat"><span>Last Active</span><span>' + agoStr + '</span></div>' +
        '</div>';
    }).join('') + '</div>';
    el.innerHTML = summaryHtml + cardsHtml;
  }

  function renderABTests(data) {
    var el = document.getElementById('stig-ab-tests');
    if (!el) return;
    var tests = (data && data.tests) || [];
    if (tests.length === 0) {
      el.innerHTML = '<div class="empty-state">No A/B tests running yet.</div>';
      return;
    }
    var html = '<div style="overflow-x:auto;"><table class="stig-ab-table"><thead><tr>' +
      '<th>Experiment</th><th>Variant A</th><th>Variant B</th><th>Metric</th><th>A</th><th>B</th><th>p-value</th><th>Winner</th>' +
      '</tr></thead><tbody>';
    html += tests.map(function(t) {
      var winClass = t.winner ? ' class="stig-ab-winner"' : '';
      return '<tr>' +
        '<td style="color:var(--text-primary);font-family:Inter,sans-serif">' + t.name + '</td>' +
        '<td>' + t.variant_a + '</td>' +
        '<td>' + t.variant_b + '</td>' +
        '<td>' + t.metric + '</td>' +
        '<td>' + (typeof t.a_value === 'number' ? t.a_value.toFixed(2) : t.a_value) + '</td>' +
        '<td>' + (typeof t.b_value === 'number' ? t.b_value.toFixed(2) : t.b_value) + '</td>' +
        '<td style="color:' + (t.p_value < 0.05 ? 'var(--emerald)' : 'var(--text-tertiary)') + '">' + (t.p_value || '—') + '</td>' +
        '<td' + winClass + '>' + (t.winner || '—') + ' (n=' + (t.n_samples || '?') + ')</td>' +
        '</tr>';
    }).join('');
    html += '</tbody></table></div>';
    el.innerHTML = html;
  }

  function renderGordonParams(data) {
    var el = document.getElementById('stig-gordon-params');
    if (!el) return;
    var params = (data && data.parameters) || [];
    if (params.length === 0) {
      el.innerHTML = '<div class="empty-state">No Gordon parameters available.</div>';
      return;
    }
    var html = '<table class="stig-gordon-table"><thead><tr><th>Parameter</th><th>Value</th><th>Description</th></tr></thead><tbody>';
    html += params.map(function(p) {
      return '<tr><td style="color:var(--cyan)">' + p.name + '</td>' +
        '<td style="color:var(--amber)">' + p.value + '</td>' +
        '<td style="font-size:0.65rem">' + (p.description || '') + '</td></tr>';
    }).join('');
    html += '</tbody></table>';
    el.innerHTML = html;
  }

  console.log('%c ASTRA v4.8 — AGI Control Room Dashboard — All 9 Tabs Active ',
    'background: linear-gradient(90deg, #ff5252, #7c4dff, #00e5ff); color: white; font-weight: bold; padding: 4px 12px; border-radius: 4px;');
})();

/* Global snapshotFor override — must be outside IIFE to patch the closure */
(function() {
  const agiData = {
    'safety-status': { state: 'NOMINAL', paused: false, safe_mode: false, audit_log: [] },
    'state-vector': { current: [0.65,0.72,0.58,0.81,0.05,0.08,0.03,0.12,0.73,0.35,0.42,0.28,0.67,0.15], history: [] },
    'alignment': { composite_score: 0.784, dimensions: { scientific_rigor: 0.82, domain_balance: 0.48, novelty_pursuit: 0.71, epistemic_humility: 0.83, resource_efficiency: 0.64, reproducibility: 0.92 } },
    'anomalies': { metrics: { confidence_drift: 0.32, exploration_balance: 0.61, domain_diversity: 0.48, value_stability: 0.55, confidence_velocity: 0.22 }, alerts: [], active: [] },
    'pending': [],
    'health': { components: { discovery_engine: {status:'ok',latency_ms:12}, safety_controller: {status:'ok',latency_ms:1}, statistics_engine: {status:'ok',latency_ms:8}, hypothesis_manager: {status:'ok',latency_ms:3}, alignment_checker: {status:'ok',latency_ms:5}, anomaly_detector: {status:'ok',latency_ms:2} } },
    // Phase 4
    'arbiter': { total_verdicts: 0, go_threshold: 0.25, no_go_threshold: 0.65, recent_verdicts: [] },
    'arbiter/verdicts': [],
    'supervisors': { total_supervisors: 2, active_supervisors: 2, active_shift: { supervisor_name: 'System Auto-Supervisor', actions_count: 0 }, total_shifts: 1, total_actions: 0 },
    'ceremony': { active_ceremony: null, total_ceremonies: 0, completed: 0 },
    'orp/assess': { go_no_go: 'CONDITIONAL_GO', readiness_pct: 100, required_ready: 16, required_total: 16 },
    'safety-case': { hazards: 10, claims: 7, max_residual_risk: 0.6, avg_confidence: 0.85 },
    'safety-case/hazards': [],
    'safety-case/claims': [],
    'safety-case/risk': { total_hazards: 10, max_residual: 0.6 },
  };
  // Patch the global api function to fall back to AGI snapshots
  const _origApi = window._astraApi;
})();

/* ==========================================================
   HYPOTHESIS PIPELINE — Dynamic rendering from snapshot data
   ========================================================== */
(function() {
  function renderHypothesisPipeline() {
    var container = document.getElementById('hyp-pipeline-content');
    if (!container) return;
    var s = window.__SNAPSHOT__;
    var hypotheses = (s && s.hypotheses) ? s.hypotheses : [];
    if (!hypotheses.length) {
      container.innerHTML = '<p style="color:var(--text-tertiary);font-size:0.8rem;">No hypothesis data available.</p>';
      return;
    }
    var phaseOrder = ['validated','testing','screening','proposed'];  // Exclude 'archived' from display
    var phaseLabels = { validated:'✓ Validated', testing:'⟳ Testing', screening:'◎ Screening', proposed:'◇ Proposed' };
    var groups = {};
    phaseOrder.forEach(function(p){ groups[p] = []; });
    hypotheses.forEach(function(h){
      var ph = (h.phase || 'proposed').toLowerCase();
      // Skip archived hypotheses - don't display them
      if (ph === 'archived') return;
      if (!groups[ph]) groups[ph] = [];
      groups[ph].push(h);
    });
    Object.keys(groups).forEach(function(k){
      groups[k].sort(function(a,b){ return (b.confidence||0) - (a.confidence||0); });
    });
    var html = '';
    phaseOrder.forEach(function(phase){
      var list = groups[phase];
      if (!list || !list.length) return;
      html += '<div class="hyp-phase-group">';
      html += '<div class="hyp-phase-label ' + phase + '">' + phaseLabels[phase] + ' <span class="hyp-count">(' + list.length + ')</span></div>';
      html += '<div class="hyp-cards">';
      list.forEach(function(h){
        var conf = h.confidence || 0;
        var pct = Math.round(conf * 100);
        var cls = conf >= 0.8 ? 'high' : conf >= 0.5 ? 'mid' : conf >= 0.3 ? 'low' : 'vlow';
        var desc = h.description || '';
        if (desc.length > 120) desc = desc.substring(0,117) + '…';
        html += '<div class="hyp-card">';
        html += '<div class="hyp-card-top"><span class="hyp-card-id">' + (h.id||'?') + '</span>';
        html += '<span class="hyp-card-domain">' + (h.domain||'General') + '</span></div>';
        html += '<div class="hyp-card-name">' + (h.name||'Unnamed') + '</div>';
        html += '<div class="hyp-card-conf"><div class="hyp-conf-bar"><div class="hyp-conf-fill ' + cls + '" style="width:' + pct + '%"></div></div>';
        html += '<span class="hyp-conf-val">' + (conf).toFixed(2) + '</span></div>';
        if (desc) html += '<div class="hyp-card-desc">' + desc + '</div>';
        html += '</div>';
      });
      html += '</div></div>';
    });
    container.innerHTML = html;
  }
  renderHypothesisPipeline();
  if (window.registerTabTimer) registerTabTimer('discoveries', setInterval(renderHypothesisPipeline, 15000));
  else setInterval(renderHypothesisPipeline, 15000);
})();
</script>
</body>
</html>





