    const entries = [
      { time: '10:33:15', type: 'system', msg: 'Engine cycle #41 completed — UPDATE phase' },
      { time: '10:33:14', type: 'discovery', msg: 'Hypothesis H014 confidence updated: 0.72 → 0.68 (KS test p=0.34)' },
      { time: '10:33:12', type: 'decision', msg: 'Auto-decision: Expand investigation scope for Dark Matter domain' },
      { time: '10:33:10', type: 'safety', msg: 'Safety gate check: PASSED — all constraints nominal' },
      { time: '10:33:05', type: 'system', msg: 'State vector computed — 14 dimensions, dist-to-boundary: 2.1σ' },
      { time: '10:32:55', type: 'discovery', msg: 'INVESTIGATE: Running KS test on Galactic Rotation Curve data (N=2500)' },
      { time: '10:32:50', type: 'system', msg: 'Anomaly check: 0 active alerts, all metrics nominal' },
      { time: '10:32:45', type: 'decision', msg: 'SELECT: Ranked 24 hypotheses, top pick: H007 (info-gain: 0.84)' },
      { time: '10:32:40', type: 'safety', msg: 'Alignment check: 78.4% composite — Domain Balance at 48% (below target)' },
      { time: '10:32:30', type: 'system', msg: 'Engine cycle #40 completed — 20.3s cycle time' },
    ];
    log.innerHTML = entries.map(e =>
