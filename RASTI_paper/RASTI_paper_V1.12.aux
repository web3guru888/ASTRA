\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces \textbf  {Test Case 7: Density Contrast vs Time from MHD Filament Fragmentation}. Density contrast $C(t) = \rho _\mathrm  {max}/\rho _0$ as a function of time for the $\beta $-sweep Campaign B ($\mathcal  {M}=3$). Magnetically stable runs ($\beta \leq 0.50$, above the critical threshold $\beta _\mathrm  {crit} = 0.667$) remain near $C\approx 1$, while unstable runs ($\beta \geq 0.70$) show rapid growth. $C_\mathrm  {final}$ at $t = 4\,t_J$ varies by $4.3\times $ across the $\beta $ range, confirming plasma $\beta $ as the dominant parameter controlling ISM filament fragmentation. The seeded fragmentation wavelength is $\lambda _\mathrm  {frag} = 2.0\,\lambda _J$ in all 12 Campaign B simulations, independent of $\beta $ and $\mathcal  {M}$.}}{17}{figure.11}\protected@file@percent }
\newlabel{fig:mhd_contrast_sweep}{{11}{17}{\textbf {Test Case 7: Density Contrast vs Time from MHD Filament Fragmentation}. Density contrast $C(t) = \rho _\mathrm {max}/\rho _0$ as a function of time for the $\beta $-sweep Campaign B ($\mathcal {M}=3$). Magnetically stable runs ($\beta \leq 0.50$, above the critical threshold $\beta _\mathrm {crit} = 0.667$) remain near $C\approx 1$, while unstable runs ($\beta \geq 0.70$) show rapid growth. $C_\mathrm {final}$ at $t = 4\,t_J$ varies by $4.3\times $ across the $\beta $ range, confirming plasma $\beta $ as the dominant parameter controlling ISM filament fragmentation. The seeded fragmentation wavelength is $\lambda _\mathrm {frag} = 2.0\,\lambda _J$ in all 12 Campaign B simulations, independent of $\beta $ and $\mathcal {M}$}{figure.11}{}}
\newlabel{eq:w3_pred}{{6}{17}{Physical Interpretation}{equation.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces \textbf  {Test Case 7: Magnetic Stability Boundary in Parameter Space}. Stability boundary (fragmentation onset) mapped by 240-simulation Campaign C in the $(f, \beta )$ plane, where $f = \sqrt  {2/\beta }$ is the mass-to-flux ratio and $f_\mathrm  {crit} = \sqrt  {3} \approx 1.73$ is the theoretical threshold. Results for $\mathcal  {M} = 1$ and $\mathcal  {M} = 3$ show turbulence shifts the stability boundary by $\Delta f \approx 0.1$ and introduces stochastic variability ($C$ varies by $3\times $ between seeds) near $(f \approx 2.3, \beta \approx 0.7)$.}}{18}{figure.12}\protected@file@percent }
\newlabel{fig:mhd_stability}{{12}{18}{\textbf {Test Case 7: Magnetic Stability Boundary in Parameter Space}. Stability boundary (fragmentation onset) mapped by 240-simulation Campaign C in the $(f, \beta )$ plane, where $f = \sqrt {2/\beta }$ is the mass-to-flux ratio and $f_\mathrm {crit} = \sqrt {3} \approx 1.73$ is the theoretical threshold. Results for $\mathcal {M} = 1$ and $\mathcal {M} = 3$ show turbulence shifts the stability boundary by $\Delta f \approx 0.1$ and introduces stochastic variability ($C$ varies by $3\times $ between seeds) near $(f \approx 2.3, \beta \approx 0.7)$}{figure.12}{}}
